{
  //direct
  "GlobalConfiguration": {
    "RequestIdKey": "RequestId",
    //LeastConnection,RoundRobin,NoLoadBalance,CookieStickySessions
    "LoadBalancerOptions": {
      "Type": "NoLoadBalance"
    },
    "UpstreamHeaderTransform": {
      "From": "gateway",
      "X-Forwarded-For": "{RemoteIpAddress}"
    },
    "DownstreamHeaderTransform": {
      "X-Forwarded-For": "{RemoteIpAddress}"
    },
    "RateLimitOptions": {
      // Whitelist entries are exempt from rate limiting
      "ClientWhitelist": [],
      // Whether rate limiting is enabled
      "EnableRateLimiting": true,
      // Rate limit period, for example: 1s, 5m, 1h, 1d
      "Period": "1s",
      // Maximum number of requests allowed within the rate limit period
      "Limit": 3000,
      // Number of seconds before the client can retry
      "PeriodTimespan": 10
    },
    "QoSOptions": {
      // Number of exceptions allowed before the circuit breaks
      "ExceptionsAllowedBeforeBreaking": 10,
      // Circuit break duration in milliseconds
      "DurationOfBreak": 30000,
      // Timeout duration
      "TimeoutValue": 5000
    }
  },
  "Routes": [
    //auth service
    {
      "DownstreamPathTemplate": "/api/auth{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/api/auth{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete",
        "Patch",
        "Options"
      ]
    },
    //admin services
    {
      "DownstreamPathTemplate": "/api/admin{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/api/admin{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete",
        "Patch",
        "Options"
      ]
    },
    //maint services
    {
      "DownstreamPathTemplate": "/api/maint{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50020
        }
      ],
      "UpstreamPathTemplate": "/api/maint{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete",
        "Patch",
        "Options"
      ]
    },
    //cust services
    {
      "DownstreamPathTemplate": "/api/cust{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50030
        }
      ],
      "UpstreamPathTemplate": "/api/cust{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete",
        "Patch",
        "Options"
      ]
    }
  ]
}
