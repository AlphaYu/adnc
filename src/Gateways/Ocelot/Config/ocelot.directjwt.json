{
  //direct
  "GlobalConfiguration": {
    "RequestIdKey": "RequestId",
    //LeastConnection,RoundRobin,NoLoadBalance,CookieStickySessions
    "LoadBalancerOptions": {
      "Type": "NoLoadBalance"
    },
    "UpstreamHeaderTransform": {
      "From": "gateway",
      "X-Forwarded-For": "{RemoteIpAddress}"
    },
    "DownstreamHeaderTransform": {
      "X-Forwarded-For": "{RemoteIpAddress}"
    },
    "RateLimitOptions": {
      // Whitelist entries are exempt from rate limiting
      "ClientWhitelist": [],
      // Whether rate limiting is enabled
      "EnableRateLimiting": true,
      // Rate limit period, for example: 1s, 5m, 1h, 1d
      "Period": "1s",
      // Maximum number of requests allowed within the rate limit period
      "Limit": 3000,
      // Number of seconds before the client can retry
      "PeriodTimespan": 10
    },
    "QoSOptions": {
      // Number of exceptions allowed before the circuit breaks
      "ExceptionsAllowedBeforeBreaking": 10,
      // Circuit break duration in milliseconds
      "DurationOfBreak": 30000,
      // Timeout duration
      "TimeoutValue": 5000
    }
  },
  "Routes": [
    //health-checker services
    {
      "DownstreamPathTemplate": "/{servicename}/health-{guid}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/{servicename}/health-{guid}",
      "UpstreamHttpMethod": [ "Get" ]
    },
    //auth service
    {
      "DownstreamPathTemplate": "/auth/session",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/auth/session",
      "UpstreamHttpMethod": [ "Post", "Put" ]
    },
    {
      "DownstreamPathTemplate": "/auth/session",
      "DownstreamScheme": "http",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "mgmt",
        "AllowedScopes": []
      },
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/auth/session",
      "UpstreamHttpMethod": [ "Get", "Delete" ]
    },
    {
      "DownstreamPathTemplate": "/auth/session/password",
      "DownstreamScheme": "http",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "mgmt",
        "AllowedScopes": []
      },
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/auth/session/password",
      "UpstreamHttpMethod": [ "Put" ]
    },
    //usr services
    {
      "DownstreamPathTemplate": "/usr{everything}",
      "DownstreamScheme": "http",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "mgmt",
        "AllowedScopes": []
      },
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50010
        }
      ],
      "UpstreamPathTemplate": "/usr{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete"
      ]
    },
    //maint services
    {
      "DownstreamPathTemplate": "/maint{everything}",
      "DownstreamScheme": "http",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "mgmt",
        "AllowedScopes": []
      },
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50020
        }
      ],
      "UpstreamPathTemplate": "/maint{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete"
      ]
    },
    //cus services
    {
      "DownstreamPathTemplate": "/cus/cap/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50030
        }
      ],
      "UpstreamPathTemplate": "/cus/cap/{everything}",
      "UpstreamHttpMethod": [ "Get"]
    },
    {
      "DownstreamPathTemplate": "/cus{everything}",
      "DownstreamScheme": "http",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "mgmt",
        "AllowedScopes": []
      },
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 50030
        }
      ],
      "UpstreamPathTemplate": "/cus{everything}",
      "UpstreamHttpMethod": [
        "Get",
        "Put",
        "Post",
        "Delete"
      ]
    }
  ]
}
