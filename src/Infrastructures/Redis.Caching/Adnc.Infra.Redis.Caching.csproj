    <PackageReference Include="SkyAPM.Core" />
    <PackageReference Include="SkyAPM.Abstractions" />
    <PackageReference Include="SkyAPM.Utilities.DependencyInjection" />
  </ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="..\Core\Adnc.Infra.Core.csproj" />
	  <ProjectReference Include="..\Redis\Adnc.Infra.Redis.csproj" />
	</ItemGroup>
</Project>
