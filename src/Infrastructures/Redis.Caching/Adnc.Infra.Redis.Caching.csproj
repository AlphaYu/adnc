		<PackageTags>adnc,redis,distributed cache</PackageTags>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Core\Interceptor\CachingPutAttribute.cs" />
	</ItemGroup>
	<ItemGroup>
